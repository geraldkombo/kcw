# =============================================================================
# Kilimo Credit Web - Production Configuration
# All values can be overridden by environment variables
# Copy to .env and fill in your secrets
# =============================================================================

# --- Neo4j ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me
NEO4J_MAX_CONNECTION_POOL_SIZE=50

# --- Featherless AI (pay-as-you-go LLM inference) ---
# Leave blank to disable LLM augmentation (agents fall back to logistic regression)
FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_MODEL=meta-llama/llama-3.1-8b-instruct

# --- Masumi x402 (Cardano payment channel for LLM escrow) ---
MASUMI_API_URL=https://payment-service.masumi.network
MASUMI_WALLET_ADDRESS=
MASUMI_WALLET_MNEMONIC=
CARDANO_NETWORK=preprod
USDM_CONTRACT_ADDR=

# --- Lovable (optional MCP API for AI-assisted dashboard) ---
LOVABLE_API_KEY=

# --- App ---
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
LOG_JSON=true
CORS_ORIGINS=*
RATE_LIMIT_PER_MINUTE=60
API_KEY=
REQUEST_ID_HEADER=X-Request-ID

# --- Securitisation ---
SECURITISATION_MIN_POOL_SIZE=100
SECURITISATION_TARGET_RATING=BBB-
DEFAULT_CURRENCY=KES

# --- NASA POWER (free satellite data for soil, water, sun) ---
# No API key needed — public NASA API, 179K+ requests/day from ag users
POWER_BASE_URL=https://power.larc.nasa.gov/api/temporal/daily/point

# --- Sprout (Mercy Corps AgriFin open content platform) ---
# CKAN migration in progress (March 2026+); leave blank until API is live
SPROUT_BASE_URL=
SPROUT_API_KEY=

# --- Google Maps Platform ---
# Get a free Maps Demo Key at https://goo.gle/maps-demo-key (no credit card)
# Leave empty to use the SVG fallback map on the dashboard
GOOGLE_MAPS_API_KEY=

# --- Data ---
DATA_DIR=data
